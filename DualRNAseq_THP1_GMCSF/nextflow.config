manifest {
    name            = 'DualRNAseq_THP1_GMCSF'
    author          = 'Seu Nome'
    description     = 'Pipeline de consenso (DESeq2 ∩ edgeR) para Dual RNA-seq multifatorial'
    nextflowVersion = '!>=23.04.0'
}

// 1. Configurações Globais dos Processos e Containers Docker
process {
    // Vincula cada processo ao seu container específico do BioContainers
    withName: FASTQC       { container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0' }
    withName: SALMON_INDEX { container = 'quay.io/biocontainers/salmon:1.10.2--h7e5f35e_0' }
    withName: SALMON_QUANT { container = 'quay.io/biocontainers/salmon:1.10.2--h7e5f35e_0' }
    withName: MULTIQC      { container = 'quay.io/biocontainers/multiqc:1.19--pyhdfd78af_0' }
    
    // Container do R atualizado com pacotes estatísticos e suporte a xlsx (openxlsx)
    withName: R_ANALYSIS   { container = 'bioconductor/bioconductor_docker:RELEASE_3_18' }
    
    // Gerenciamento de recursos para não travar o Windows
    cpus   = 2
    memory = '4 GB'
}

// 2. Ativação do Perfil Docker no Windows via WSL2
profiles {
    docker {
        docker.enabled       = true
        docker.userEmulation = true
        docker.runOptions    = '-v /var/run/docker.sock:/var/run/docker.sock'
    }
}

// 3. Geração de relatórios automáticos de execução do Nextflow
timeline.enabled = true
timeline.file    = "${params.outdir}/pipeline_info/execution_timeline.html"
report.enabled   = true
report.file      = "${params.outdir}/pipeline_info/execution_report.html"